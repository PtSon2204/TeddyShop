{
  // ==========================================================================
  //  appsettings.json — Đọc giá trị từ biến môi trường (.env)
  //  Cú pháp: ${TEN_BIEN} sẽ được thay thế bởi DotNetEnv
  //  Các giá trị thật đặt trong file .env (không commit lên Git)
  // ==========================================================================

  "ConnectionStrings": {
    // Npgsql connection string — ghép từ các biến DB_*
    "DefaultConnection": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}"
  },

  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "AccessTokenExpiryMinutes": "${JWT_ACCESS_TOKEN_EXPIRY_MINUTES}",
    "RefreshTokenExpiryDays": "${JWT_REFRESH_TOKEN_EXPIRY_DAYS}"
  },

  "Redis": {
    "ConnectionString": "${REDIS_CONNECTION_STRING}",
    "InstanceName": "${REDIS_INSTANCE_NAME}"
  },

  "RabbitMQ": {
    "Host": "${RABBITMQ_HOST}",
    "Port": "${RABBITMQ_PORT}",
    "Username": "${RABBITMQ_USERNAME}",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "${RABBITMQ_VIRTUAL_HOST}"
  },

  "Cloudinary": {
    "CloudName": "${CLOUDINARY_CLOUD_NAME}",
    "ApiKey": "${CLOUDINARY_API_KEY}",
    "ApiSecret": "${CLOUDINARY_API_SECRET}"
  },

  "VietQR": {
    "BankCode": "${VIETQR_BANK_CODE}",
    "AccountNumber": "${VIETQR_ACCOUNT_NUMBER}",
    "AccountName": "${VIETQR_ACCOUNT_NAME}"
  },

  "SePay": {
    "WebhookSecretKey": "${SEPAY_WEBHOOK_SECRET_KEY}",
    "ApiKey": "${SEPAY_API_KEY}"
  },

  "Email": {
    "Host": "${EMAIL_HOST}",
    "Port": "${EMAIL_PORT}",
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "FromName": "${EMAIL_FROM_NAME}",
    "UseSsl": "${EMAIL_USE_SSL}"
  },

  "Cors": {
    "AllowedOrigins": [ "${CORS_ALLOWED_ORIGINS}" ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
