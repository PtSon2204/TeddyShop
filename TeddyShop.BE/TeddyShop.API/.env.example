# =============================================================================
#  TeddyShop — Environment Variables EXAMPLE
#  ✅  File này ĐƯỢC commit lên Git (không có giá trị thật)
#  📋  Copy file này thành .env rồi điền giá trị thật vào
#      cp .env.example .env
# =============================================================================


# =============================================================================
#  🗄️  DATABASE — PostgreSQL
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teddyshop_db
DB_USER=postgres
DB_PASSWORD=


# =============================================================================
#  🔐  JWT — Authentication
# =============================================================================
JWT_SECRET_KEY=
JWT_ISSUER=TeddyShopAPI
JWT_AUDIENCE=TeddyShopClient
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7


# =============================================================================
#  🔴  REDIS — Caching
# =============================================================================
REDIS_CONNECTION_STRING=localhost:6379
REDIS_INSTANCE_NAME=TeddyShop_


# =============================================================================
#  🐇  RABBITMQ — Message Queue
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/


# =============================================================================
#  ☁️  CLOUDINARY — Image Storage
# =============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# =============================================================================
#  💳  VIETQR — Payment
# =============================================================================
VIETQR_BANK_CODE=MB
VIETQR_ACCOUNT_NUMBER=
VIETQR_ACCOUNT_NAME=TEDDY SHOP


# =============================================================================
#  💳  SEPAY — Payment Webhook
# =============================================================================
SEPAY_WEBHOOK_SECRET_KEY=
SEPAY_API_KEY=


# =============================================================================
#  📧  EMAIL — SMTP (MailKit)
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=TeddyShop
EMAIL_USE_SSL=false


# =============================================================================
#  🌐  CORS — Frontend Origin
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173


# =============================================================================
#  ⚙️  APP — General
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
