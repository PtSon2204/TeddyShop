# =============================================================================
#  🐳 DOCKER — Local volumes & runtime data
# =============================================================================

# Volume data được mount từ host (không cần push, Docker tự tạo)
docker/data/
docker/volumes/
postgres-data/
redis-data/
rabbitmq-data/
rabbitmq/data/
rabbitmq/log/

# Docker override cho máy cá nhân (không nên push)
docker-compose.local.yml
docker-compose.*.local.yml

# Giữ lại (sẽ commit):
# docker-compose.yml            ← production compose
# docker-compose.override.yml   ← dev defaults (không chứa secret thật)
# Dockerfile                    ← image definition


