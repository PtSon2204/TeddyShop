# =============================================================================
#  TeddyShop — .gitignore
#  Covers: ASP.NET Core BE + React/TypeScript FE + Docker + IDE + OS
# =============================================================================


# =============================================================================
#  🔐 SECRETS & ENVIRONMENT — TUYỆT ĐỐI không push
# =============================================================================

# .env files (chỉ giữ file example)
.env
.env.*
!.env.example
!.env.*.example

# appsettings chứa thông tin nhạy cảm
**/appsettings.Local.json
**/appsettings.Production.json
**/appsettings.Staging.json
**/appsettings.*.Secret.json

# Certificates & private keys
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
*.ppk
*.jks
*.keystore

# Google / Firebase service accounts
*service-account*.json
*credentials*.json
firebase-adminsdk*.json
google-credentials.json
serviceAccountKey.json

# AWS
.aws/
aws-credentials.json

# JWT / Token secrets files
secrets.json
**/secrets.json

# Rider HTTP Client private env (chứa tokens)
http-client.private.env.json

# Postman environments (có thể chứa Bearer tokens)
*postman_environment*.json
!*postman_collection*.json


